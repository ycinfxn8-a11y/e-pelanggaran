# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# Appwrite endpoint (default: cloud.appwrite.io)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Project ID dari Appwrite Console > Settings
VITE_APPWRITE_PROJECT=GANTI_PROJECT_ID

# Database ID (default: siswapro)
VITE_DB_ID=siswapro

# Document ID untuk dokumen pengaturan tunggal (default: main)
VITE_PENGATURAN_DOC_ID=main
